---
import Layout from '../layouts/Layout.astro';
import TelegramStream from '../components/TelegramStream.astro';
---

<Layout
  title="KNXplorer — Coming Soon"
  description="KNX bus monitoring and project explorer for iOS and macOS. Coming 2026."
>
  <main class="page">
    <TelegramStream />

    <div class="content">
      <div class="logo-mark">K</div>
      <h1 class="title">KNXplorer</h1>
      <p class="tagline">
        KNX bus monitor & project explorer<br />
        for iPhone, iPad, and Mac.
      </p>
      <div class="divider"></div>
      <p class="coming">Coming 2026</p>
      <a href="mailto:knxplorer@freiwald.dev" class="notify">Get notified</a>
    </div>

    <footer class="footer">
      <a href="https://freiwald.dev">Michael Freiwald</a>
      <span class="sep">/</span>
      <a href="/privacy">Privacy</a>
    </footer>
  </main>
</Layout>

<style>
  .page {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
  }

  .page::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 40% at 50% 45%, var(--accent-glow), transparent),
      radial-gradient(ellipse 80% 70% at 50% 50%, rgba(13, 13, 13, 0.97), transparent);
    z-index: 1;
  }

  .content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .logo-mark {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--bg-primary);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 28px;
    border-radius: 14px;
    margin-bottom: 28px;
    animation: fade-up 0.8s ease-out both;
  }

  .title {
    font-size: clamp(36px, 8vw, 64px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 16px;
    animation: fade-up 0.8s ease-out 0.1s both;
  }

  .tagline {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.5;
    animation: fade-up 0.8s ease-out 0.2s both;
  }

  .divider {
    width: 32px;
    height: 1px;
    background: var(--border);
    margin: 32px 0;
    animation: fade-up 0.8s ease-out 0.3s both;
  }

  .coming {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 24px;
    animation: fade-up 0.8s ease-out 0.35s both;
  }

  .notify {
    font-size: 14px;
    font-weight: 500;
    color: var(--bg-primary);
    background: var(--accent);
    padding: 10px 24px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    animation: fade-up 0.8s ease-out 0.4s both;
  }

  .notify:hover {
    background: var(--accent-bright);
    transform: translateY(-1px);
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .footer {
    position: absolute;
    bottom: 24px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .footer a {
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer a:hover {
    color: var(--text-secondary);
  }

  .sep {
    color: var(--border);
  }
</style>
