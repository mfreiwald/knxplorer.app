---
// Animated KNX telegram lines for the hero background
const telegrams = [
  { time: "14:32:05.831", dir: "→", src: "1.1.4", dest: "2/1/0", type: "GroupValueWrite", value: "ON", dpt: "DPT1" },
  { time: "14:32:05.847", dir: "←", src: "1.1.12", dest: "3/0/1", type: "GroupValueResp", value: "21.4°C", dpt: "DPT9" },
  { time: "14:32:06.102", dir: "→", src: "1.2.1", dest: "2/3/5", type: "GroupValueWrite", value: "75%", dpt: "DPT5" },
  { time: "14:32:06.330", dir: "←", src: "1.1.8", dest: "1/0/12", type: "GroupValueRead", value: "—", dpt: "" },
  { time: "14:32:06.512", dir: "→", src: "1.3.2", dest: "4/1/0", type: "GroupValueWrite", value: "OFF", dpt: "DPT1" },
  { time: "14:32:07.001", dir: "←", src: "1.1.4", dest: "2/1/3", type: "GroupValueResp", value: "1850 lux", dpt: "DPT9" },
  { time: "14:32:07.215", dir: "→", src: "1.2.5", dest: "3/2/0", type: "GroupValueWrite", value: "Scene 4", dpt: "DPT17" },
  { time: "14:32:07.490", dir: "←", src: "1.1.12", dest: "3/0/2", type: "GroupValueResp", value: "45%", dpt: "DPT5" },
  { time: "14:32:07.712", dir: "→", src: "1.4.1", dest: "5/0/0", type: "GroupValueWrite", value: "22.0°C", dpt: "DPT9" },
  { time: "14:32:08.003", dir: "←", src: "1.1.6", dest: "1/2/8", type: "GroupValueRead", value: "—", dpt: "" },
  { time: "14:32:08.198", dir: "→", src: "1.1.4", dest: "2/1/0", type: "GroupValueWrite", value: "OFF", dpt: "DPT1" },
  { time: "14:32:08.411", dir: "←", src: "1.2.3", dest: "3/1/5", type: "GroupValueResp", value: "ON", dpt: "DPT1" },
];
---

<div class="telegram-stream" aria-hidden="true">
  <div class="telegram-track">
    {telegrams.map((t, i) => (
      <div class="telegram-line" style={`animation-delay: ${i * 0.7}s`}>
        <span class="tg-time">{t.time}</span>
        <span class={`tg-dir ${t.dir === '→' ? 'out' : 'in'}`}>{t.dir}</span>
        <span class="tg-addr">{t.src}</span>
        <span class="tg-sep">▸</span>
        <span class="tg-ga">{t.dest}</span>
        <span class="tg-type">{t.type}</span>
        <span class={`tg-value ${t.value === 'ON' ? 'val-on' : t.value === 'OFF' ? 'val-off' : ''}`}>{t.value}</span>
        {t.dpt && <span class="tg-dpt">{t.dpt}</span>}
      </div>
    ))}
  </div>
  <div class="telegram-track" aria-hidden="true">
    {telegrams.map((t, i) => (
      <div class="telegram-line" style={`animation-delay: ${(i + telegrams.length) * 0.7}s`}>
        <span class="tg-time">{t.time}</span>
        <span class={`tg-dir ${t.dir === '→' ? 'out' : 'in'}`}>{t.dir}</span>
        <span class="tg-addr">{t.src}</span>
        <span class="tg-sep">▸</span>
        <span class="tg-ga">{t.dest}</span>
        <span class="tg-type">{t.type}</span>
        <span class={`tg-value ${t.value === 'ON' ? 'val-on' : t.value === 'OFF' ? 'val-off' : ''}`}>{t.value}</span>
        {t.dpt && <span class="tg-dpt">{t.dpt}</span>}
      </div>
    ))}
  </div>
</div>

<style>
  .telegram-stream {
    position: absolute;
    inset: 0;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 2.2;
    opacity: 0.12;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 20%,
      black 80%,
      transparent 100%
    );
    pointer-events: none;
    user-select: none;
  }

  .telegram-track {
    animation: scroll-telegrams 28s linear infinite;
  }

  .telegram-track:nth-child(2) {
    /* Seamless loop continuation */
  }

  @keyframes scroll-telegrams {
    from { transform: translateY(0); }
    to { transform: translateY(-100%); }
  }

  .telegram-line {
    white-space: nowrap;
    display: flex;
    gap: 12px;
    padding: 0 20px;
    animation: fade-line 0.6s ease-out both;
  }

  @keyframes fade-line {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .tg-time { color: var(--text-tertiary); }
  .tg-dir.out { color: var(--accent); }
  .tg-dir.in { color: var(--blue); }
  .tg-addr { color: var(--text-secondary); min-width: 50px; }
  .tg-sep { color: var(--text-tertiary); font-size: 10px; }
  .tg-ga { color: var(--accent-bright); min-width: 55px; }
  .tg-type { color: var(--text-secondary); min-width: 140px; }
  .tg-value { color: var(--text-primary); min-width: 70px; }
  .tg-value.val-on { color: var(--green); }
  .tg-value.val-off { color: var(--red); }
  .tg-dpt { color: var(--text-tertiary); font-size: 11px; }
</style>
